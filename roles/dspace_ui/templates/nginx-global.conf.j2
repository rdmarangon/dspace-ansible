tcp_nodelay       on;
keepalive_timeout 75;

client_max_body_size  50m;
client_body_timeout   120s;
client_header_timeout 30s;
send_timeout          120s;

gzip_vary       on;
gzip_proxied    any;
gzip_comp_level 5;
gzip_min_length 1024;
gzip_types
    text/plain
    text/css
    application/json
    application/javascript
    application/xml+rss
    image/svg+xml;

limit_req_zone $binary_remote_addr zone=auth:10m rate=10r/m;
